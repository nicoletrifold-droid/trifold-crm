{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@trifold/web",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/enrich-leads",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/followup",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/campaign-poll",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/meta-ads-intelligence",
      "schedule": "0 11 * * *"
    }
  ]
}
