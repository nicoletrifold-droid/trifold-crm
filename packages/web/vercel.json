{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@trifold/web",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/dashboard/metrics",
      "headers": [
        { "key": "Cache-Control", "value": "private, s-maxage=30, stale-while-revalidate=120" }
      ]
    },
    {
      "source": "/api/analytics",
      "headers": [
        { "key": "Cache-Control", "value": "private, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/analytics/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/enrich-leads",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/followup",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/campaign-poll",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/meta-sync-entities",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/meta-sync-insights",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/webhook-health",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/meta-sync-health",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/email-automations",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/email-queue",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/meta-ads-intelligence",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/calendly-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/supremo-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/supremo-history-sync",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/appointment-email-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/appointment-whatsapp-reminders",
      "schedule": "*/30 * * * *"
    }
  ]
}
